# Set to "true" to expose the Ollama (local) backend option in the UI and allow
# the server to proxy requests to a local Ollama instance. Leave unset/false for
# public cloud deployments where localhost Ollama isn't reachable.
NEXT_PUBLIC_ALLOW_OLLAMA=false

# Base URL for the Ollama instance the server should talk to (only used when
# NEXT_PUBLIC_ALLOW_OLLAMA=true). Defaults to http://localhost:11434.
OLLAMA_BASE_URL=http://localhost:11434
